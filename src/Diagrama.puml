@startuml
skinparam classAttributeIconSize 0
skinparam monochrome true
skinparam shadowing false

' ==================== CLASSES ====================
class Livro {
  - titulo : String
  - autor : String
  - isbn : long
  - quantidade : int
  - emprestados : int
  + emprestar() : boolean
  + devolver() : void
}

class Leitor {
  - nomeUsuario : String
  - id : int
  - livrosEmprestados : List<Livro>
  + pegarLivro(livro : Livro) : void
  + devolverLivro(livro : Livro) : void
}

class Biblioteca {
  - livros : List<Livro>
  - leitores : List<Leitor>
  + cadastrarLivro(livro : Livro) : void
  + cadastrarLeitor(leitor : Leitor) : void
  + buscarLivroPorTitulo(titulo : String) : Livro
  + listarLivrosDisponiveis() : List<Livro>
}

class Login extends JFrame {
  ' Tela de login do sistema
}

class Principal extends JFrame {
  ' Tela principal do sistema
}

class Main {
  + main(args : String[]) : void
}

' ==================== RELACIONAMENTOS ====================
Biblioteca "1" *-- "muitos" Livro : contém
Biblioteca "1" *-- "muitos" Leitor : gerencia
Leitor "1" --> "0..muitos" Livro : possui emprestado
Main --> Login : inicia
Login --> Principal : abre após login
Principal --> Biblioteca : usa

@enduml
